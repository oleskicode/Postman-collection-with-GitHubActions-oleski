    {
      "name": "02_Create_article",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "a7a0c302-1d05-4b10-9f34-bdac5922b503",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has article object\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property(\"article\");",
              "});",
              "",
              "pm.test(\"Article has required fields\", function () {",
              "    const article = pm.response.json().article;",
              "    pm.expect(article).to.have.property(\"slug\");",
              "    pm.expect(article).to.have.property(\"title\");",
              "    pm.expect(article).to.have.property(\"description\");",
              "    pm.expect(article).to.have.property(\"body\");",
              "    pm.expect(article).to.have.property(\"tagList\");",
              "    pm.expect(article).to.have.property(\"createdAt\");",
              "    pm.expect(article).to.have.property(\"updatedAt\");",
              "    pm.expect(article).to.have.property(\"author\");",
              "});",
              "",
              "pm.test(\"Article title matches request\", function () {",
              "    const article = pm.response.json().article;",
              "    pm.expect(article.title).to.eql(\"Postman Test Article\");",
              "});",
              "",
              "pm.test(\"Article tagList is an array\", function () {",
              "    const article = pm.response.json().article;",
              "    pm.expect(article.tagList).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Article author has username\", function () {",
              "    const article = pm.response.json().article;",
              "    pm.expect(article.author).to.have.property(\"username\");",
              "});",
              "",
              "pm.test(\"Save article slug to environment\", function () {",
              "    const article = pm.response.json().article;",
              "    pm.environment.set(\"ARTICLE_SLUG\", article.slug);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
