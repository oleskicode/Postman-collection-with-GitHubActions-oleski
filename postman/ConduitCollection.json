    {
      "name": "01_Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "45f55fb7-5b00-4298-9e97-d473fd055c35",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has user object\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"user\");",
              "});",
              "",
              "pm.test(\"User has required fields\", function () {",
              "    const user = pm.response.json().user;",
              "    pm.expect(user).to.have.property(\"email\");",
              "    pm.expect(user).to.have.property(\"username\");",
              "    pm.expect(user).to.have.property(\"token\");",
              "});",
              "",
              "pm.test(\"Token is a non-empty string\", function () {",
              "    const token = pm.response.json().user.token;",
              "    pm.expect(token).to.be.a(\"string\").and.to.have.length.above(0);",
              "});",
              "",
              "pm.test(\"Response time is less than 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// Save token to environment for use in subsequent requests",
              "const jsonData = pm.response.json();",
              "if (jsonData.user && jsonData.user.token) {",
              "    pm.environment.set(\"AUTH_TOKEN\", jsonData.user.token);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
