  "item": [
    {
      "name": "00_Global_setup_register_user",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "cea0a616-bba3-402d-abe6-a7d30bc58124",
            "exec": [
              "",
              "pm.test(\"Status code is 200, 201, or 422\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 422]);",
              "});",
              "",
              "pm.test(\"Response time is acceptable\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});",
              "",
              "pm.test(\"Response has JSON content-type\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    pm.test(\"On success (2xx): response body has user object\", function () {",
              "        var jsonData = pm.response.json();",
              "        pm.expect(jsonData).to.have.property(\"user\");",
              "        pm.expect(jsonData.user).to.have.property(\"email\");",
              "        pm.expect(jsonData.user).to.have.property(\"username\");",
              "        pm.expect(jsonData.user).to.have.property(\"token\");",
              "    });",
              "",
              "    pm.test(\"On success (2xx): store auth token as environment variable\", function () {",
              "        var jsonData = pm.response.json();",
              "        pm.environment.set(\"AUTH_TOKEN\", jsonData.user.token);",
              "    });",
              "}",
              "",
              "if (pm.response.code === 422) {",
              "    console.warn(\"User already exists — continuing setup script without registration.\");",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
